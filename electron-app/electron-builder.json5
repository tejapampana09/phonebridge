{
  "appId": "com.phonebridge.app",
  "productName": "PhoneBridge",
  "npmRebuild": false,
  "copyright": "Copyright © 2026",
  "directories": {
    "buildResources": "build",
    "output": "dist"
  },
  "files": [
    "dist-electron/**",
    "out/**"
  ],
  "win": {
    "target": [
      {"target": "nsis", "arch": ["x64"]},
      {"target": "dir", "arch": ["x64"]}
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  }
}
